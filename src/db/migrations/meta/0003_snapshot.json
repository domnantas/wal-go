      "policies": {
        "Authenticated can insert/select/update/delete own QSOs": {
          "name": "Authenticated can insert/select/update/delete own QSOs",
          "as": "PERMISSIVE",
          "for": "ALL",
          "to": [
            "authenticated"
          ],
          "using": "((select auth.uid()) is not null and (select auth.uid()) = \"qsos\".\"user_id\")"
        }
      },
      "checkConstraints": {
        "callsign_format": {
          "name": "callsign_format",
          "value": "length(\"qsos\".\"received_callsign\") >= 3 AND length(\"qsos\".\"received_callsign\") <= 10"
        },
        "received_wal_format": {
          "name": "received_wal_format",
          "value": "\"qsos\".\"received_wal\" IS NULL OR \"qsos\".\"received_wal\" = '' OR \"qsos\".\"received_wal\" ~ '^[A-P][0-9]{2}$'"
        },
        "sent_wal_format": {
          "name": "sent_wal_format",
          "value": "\"qsos\".\"sent_wal\" IS NULL OR \"qsos\".\"sent_wal\" = '' OR \"qsos\".\"sent_wal\" ~ '^[A-P][0-9]{2}$'"
        },
        "received_rst_format": {
          "name": "received_rst_format",
          "value": "\"qsos\".\"received_rst\" ~ '^[1-5][1-9][1-9]?$'"
        },
        "sent_rst_format": {
          "name": "sent_rst_format",
          "value": "\"qsos\".\"sent_rst\" ~ '^[1-5][1-9][1-9]?$'"
        },
        "mode_valid": {
          "name": "mode_valid",
          "value": "\"qsos\".\"mode\" IN ('SSB', 'CW', 'DIGI')"
        }
      },
