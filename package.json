{
  "name": "WAL-GO",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @WAL-GO/db db:push",
    "db:studio": "turbo -F @WAL-GO/db db:studio",
    "db:generate": "turbo -F @WAL-GO/db db:generate",
    "db:migrate": "turbo -F @WAL-GO/db db:migrate",
    "db:seed": "turbo -F @WAL-GO/db db:seed",
    "deploy": "pnpm --dir packages/infra exec alchemy deploy",
    "destroy": "pnpm --dir packages/infra exec alchemy destroy",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@WAL-GO/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@WAL-GO/config": "workspace:*",
    "@biomejs/biome": "2.4.12",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.0"
  },
  "packageManager": "pnpm@10.33.0"
}
